# Postgres (matches docker-compose.dev.yml)
DATABASE_URL=postgres://scanner:scanner@localhost:5433/scanner

# Auth.js
# Generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-32-byte-hex-string-from-openssl
AUTH_URL=http://localhost:3200

# Resend (https://resend.com)
RESEND_API_KEY=re_change_me
EMAIL_FROM=noreply@example.com

# Redis (optional in Phase 1; required from Phase 5 onwards)
REDIS_URL=redis://localhost:6380

# Shared secret between the prod trading server (which pushes the daily scan
# JSON) and this site's /api/ingest/scan endpoint. Generate with:
#   openssl rand -hex 32
INGEST_SHARED_SECRET=replace-with-32-byte-hex-string

# Whop OAuth + billing
# Get from whop.com → My Products → <product> → OAuth credentials
WHOP_CLIENT_ID=
WHOP_CLIENT_SECRET=
# API key for server-side membership lookups: whop.com → My Products → <product> → API Keys
WHOP_API_KEY=
# Webhook signing secret: whop.com → Webhooks → <hook> → Signing secret
WHOP_WEBHOOK_SECRET=
# Membership pass / product ID (looks like pass_XXXXX)
WHOP_PASS_ID=
# Public hosted checkout link
WHOP_CHECKOUT_URL=https://whop.com/checkout/...

# Web Push (VAPID). Generate once with:
#   pnpm tsx scripts/generate-vapid.ts
# Then paste the 4 lines below into this file (or .env.local). The public key
# is also exposed to the client via NEXT_PUBLIC_VAPID_PUBLIC_KEY so the
# browser can call pushManager.subscribe().
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:ops@mrstocks.cash
